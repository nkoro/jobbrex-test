run = "streamlit run app.py --server.port $PORT --server.headless true --server.address 0.0.0.0"
entrypoint = "app.py"
modules = ["python-3.10"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "streamlit run app.py --server.port $PORT --server.headless true --server.address 0.0.0.0"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8501
externalPort = 80
